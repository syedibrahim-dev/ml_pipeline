{
  "uid": "fraud-system-health",
  "title": "1. System Health Dashboard",
  "description": "API request rate, latency, error rate, CPU and memory usage",
  "tags": ["fraud-detection", "system"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "API Request Rate (req/s)",
      "description": "Number of API requests per second by endpoint",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(fraud_api_requests_total[1m])",
          "legendFormat": "{{endpoint}} - {{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {"mode": "palette-classic"}
        }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "API Latency (P50 / P95 / P99)",
      "description": "Response time percentiles for /predict endpoint",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.50, rate(fraud_api_request_duration_seconds_bucket{endpoint='/predict'}[5m]))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, rate(fraud_api_request_duration_seconds_bucket{endpoint='/predict'}[5m]))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.99, rate(fraud_api_request_duration_seconds_bucket{endpoint='/predict'}[5m]))",
          "legendFormat": "P99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "s"}
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Error Rate (5xx)",
      "description": "Percentage of requests returning 500 errors",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(fraud_api_requests_total{status='500'}[5m]) / rate(fraud_api_requests_total[5m]) * 100",
          "legendFormat": "Error Rate %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 5}
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "CPU Usage",
      "description": "CPU utilisation of the fraud-api container",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(container_cpu_usage_seconds_total{name='fraud-api'}[1m]) * 100",
          "legendFormat": "CPU %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "percent"}
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Memory Usage",
      "description": "Memory consumption of the fraud-api container",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "container_memory_usage_bytes{name='fraud-api'}",
          "legendFormat": "Memory",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "bytes"}
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Total Predictions (last 1h)",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 16},
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "increase(fraud_api_requests_total{endpoint='/predict', status='200'}[1h])",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "short", "color": {"mode": "fixed", "fixedColor": "blue"}}
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "API Health",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 16},
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "up{job='fraud-api'}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {"options": {"0": {"text": "DOWN", "color": "red"}}, "type": "value"},
            {"options": {"1": {"text": "UP", "color": "green"}}, "type": "value"}
          ]
        }
      }
    }
  ]
}
